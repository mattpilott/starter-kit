{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"svelte": true,
	"useTabs": true,
	"singleQuote": true,
	"trailingComma": "none",
	"printWidth": 115,
	"tabWidth": 3,
	"arrowParens": "avoid",
	"semi": false,
	"bracketSameLine": true,
	"sortPackageJson": false,
	"ignorePatterns": [".claude"]
}
